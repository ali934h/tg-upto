# Telegram bot credentials
BOT_TOKEN=
API_ID=
API_HASH=

# CSV of Telegram numeric user ids allowed to use the bot
ALLOWED_USERS=

# Google OAuth client (Desktop type) created at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Long-lived refresh token obtained via `node setup-drive.js`
GOOGLE_REFRESH_TOKEN=

# Optional: target folder id in My Drive (leave blank to upload to root)
DRIVE_FOLDER_ID=

# Working directory for buffered downloads
UPLOAD_DIR=/root/tg-upto-uploads

# Logging
LOG_LEVEL=info
